#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")"
DOTFILES_ROOT="$(pwd -P)"

HL=$'\e[0;92m'
WARN=$'\e[91m'
END=$'\e[0m\e[39m\e[49m'

overwrite_all=false
backup_all=false
skip_all=false

main() {
  heading "@robotnorman dotfiles bootstrap"

  heading "Setting up git identity"
  setup_gitconfig

  heading "Linking dotfiles"
  install_dotfiles

  heading "Setting up Homebrew"
  setup_homebrew

  heading "Installing Homebrew bundle"
  brew bundle --file "$DOTFILES_ROOT/Brewfile"

  heading "Configuring default shell"
  setup_default_shell

  heading "Running topic installers"
  run_installers

  heading "Optional follow-up"
  printf '%s\n' \
    "1. Set your terminal profile font to JetBrainsMono Nerd Font so Starship prompt glyphs render correctly."

  heading "Done"
}

setup_homebrew() {
  if ! command -v brew >/dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  else
    fail "Homebrew install did not leave brew on PATH"
  fi

  success "brew $(brew --version | head -n 1)"
}

setup_gitconfig() {
  if [ -f "$DOTFILES_ROOT/git/.gitconfig.local" ]; then
    success "git/.gitconfig.local already exists"
    return
  fi

  local git_credential="cache"
  if [ "$(uname -s)" = "Darwin" ]; then
    git_credential="osxkeychain"
  fi

  user "Git author name?"
  read -r git_authorname
  user "Git author email?"
  read -r git_authoremail

  sed \
    -e "s/AUTHORNAME/$git_authorname/g" \
    -e "s/AUTHOREMAIL/$git_authoremail/g" \
    -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" \
    "$DOTFILES_ROOT/git/.gitconfig.local.example" >"$DOTFILES_ROOT/git/.gitconfig.local"

  success "created git/.gitconfig.local"
}

setup_default_shell() {
  local target_shell="/bin/zsh"
  local current_shell

  current_shell="$(get_login_shell)"
  if [ "$current_shell" = "$target_shell" ]; then
    success "$target_shell is already your default shell"
    return
  fi

  if [ ! -x "$target_shell" ]; then
    success "$target_shell is not available; skipping default shell setup"
    return
  fi

  if ! confirm "Set $target_shell as your default login shell?"; then
    success "skipped default shell setup"
    return
  fi

  ensure_shell_allowed "$target_shell"

  if ! command -v chsh >/dev/null 2>&1; then
    fail "chsh is not available; could not set default shell"
  fi

  chsh -s "$target_shell"
  success "set default shell to $target_shell"
}

get_login_shell() {
  local current_shell=

  if command -v dscl >/dev/null 2>&1; then
    current_shell="$(dscl . -read "/Users/$(id -un)" UserShell 2>/dev/null | awk '{print $2}' || true)"
  elif command -v getent >/dev/null 2>&1; then
    current_shell="$(getent passwd "$(id -un)" | cut -d: -f7 || true)"
  fi

  printf '%s\n' "${current_shell:-${SHELL:-}}"
}

ensure_shell_allowed() {
  local target_shell=$1
  local shells_file="/etc/shells"

  if [ -f "$shells_file" ] && grep -Fxq "$target_shell" "$shells_file"; then
    return
  fi

  if ! confirm "$target_shell is not listed in $shells_file. Add it with sudo?"; then
    fail "$target_shell must be listed in $shells_file before chsh can use it"
  fi

  if ! printf '%s\n' "$target_shell" | sudo tee -a "$shells_file" >/dev/null; then
    fail "could not add $target_shell to $shells_file"
  fi

  success "added $target_shell to $shells_file"
}

install_dotfiles() {
  while IFS= read -r -d '' -u 3 src; do
    local dst
    dst="$HOME/$(basename "$src")"
    link_file "$src" "$dst"
  done 3< <(
    find -H "$DOTFILES_ROOT" \
      -mindepth 2 \
      -maxdepth 2 \
      -name '.*' \
      ! -name '.DS_Store' \
      ! -name '*.example' \
      ! -path '*/.git/*' \
      -print0
  )
}

run_installers() {
  while IFS= read -r -u 3 installer; do
    success "running ${installer#"$DOTFILES_ROOT"/}"
    (
      cd "$(dirname "$installer")"
      DOTFILES_ROOT="$DOTFILES_ROOT" bash "$installer"
    )
  done 3< <(
    find "$DOTFILES_ROOT" \
      -name install.sh \
      ! -path "$DOTFILES_ROOT/.git/*" \
      -print | sort
  )
}

link_file() {
  local src=$1
  local dst=$2
  local overwrite=false
  local backup=false
  local skip=false
  local action=

  if [ -e "$dst" ] || [ -L "$dst" ]; then
    local current_src=
    current_src="$(readlink "$dst" 2>/dev/null || true)"

    if [ "$current_src" = "$src" ]; then
      skip=true
    elif [ "$overwrite_all" = false ] && [ "$backup_all" = false ] && [ "$skip_all" = false ]; then
      user "File exists: $dst ($(basename "$src")). [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
      if ! read -r -n 1 action; then
        action=s
      fi
      printf '\n'

      case "$action" in
        o) overwrite=true ;;
        O) overwrite_all=true ;;
        b) backup=true ;;
        B) backup_all=true ;;
        s) skip=true ;;
        S) skip_all=true ;;
        *) skip=true ;;
      esac
    fi

    [ "$overwrite_all" = true ] && overwrite=true
    [ "$backup_all" = true ] && backup=true
    [ "$skip_all" = true ] && skip=true

    if [ "$overwrite" = true ]; then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" = true ]; then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" = true ]; then
      success "skipped $dst"
    fi
  fi

  if [ "$skip" != true ]; then
    ln -s "$src" "$dst"
    success "linked $dst"
  fi
}

heading() {
  printf '\n  [..] %s%s%s\n' "$HL" "$1" "$END"
}

user() {
  printf '  [??] %s\n' "$1"
}

confirm() {
  local prompt=$1
  local answer=

  user "$prompt [y/N]"
  if ! read -r -n 1 answer; then
    answer=
  fi
  printf '\n'

  [ "$answer" = "y" ] || [ "$answer" = "Y" ]
}

success() {
  printf '  [OK] %s\n' "$1"
}

fail() {
  printf '  [FAIL] %s%s%s\n' "$WARN" "$1" "$END"
  exit 1
}

main "$@"
