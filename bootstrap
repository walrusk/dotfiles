#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")"
DOTFILES_ROOT="$(pwd -P)"

HL=$'\e[0;92m'
WARN=$'\e[91m'
END=$'\e[0m\e[39m\e[49m'

overwrite_all=false
backup_all=false
skip_all=false

main() {
  heading "@walrusk dotfiles bootstrap"

  heading "Setting up git identity"
  setup_gitconfig

  heading "Linking dotfiles"
  install_dotfiles

  heading "Setting up Homebrew"
  setup_homebrew

  heading "Installing Homebrew bundle"
  brew bundle --file "$DOTFILES_ROOT/Brewfile"

  heading "Running topic installers"
  run_installers

  heading "Manual follow-up"
  printf '%s\n' \
    "1. Set your default shell to Homebrew zsh if needed:" \
    "   chsh -s \"$(brew --prefix)/bin/zsh\"" \
    "2. Keyboard Settings -> Keyboard Shortcuts -> Function Keys -> Use F1, F2, etc. as standard function keys" \
    "3. Keyboard Settings -> Modifier Keys -> map Caps Lock to Control" \
    "4. Start the local container runtime when needed with: colima start"

  heading "Done"
}

setup_homebrew() {
  if ! command -v brew >/dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
  elif [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  else
    fail "Homebrew install did not leave brew on PATH"
  fi

  success "brew $(brew --version | head -n 1)"
}

setup_gitconfig() {
  if [ -f "$DOTFILES_ROOT/git/.gitconfig.local" ]; then
    success "git/.gitconfig.local already exists"
    return
  fi

  local git_credential="cache"
  if [ "$(uname -s)" = "Darwin" ]; then
    git_credential="osxkeychain"
  fi

  user "Git author name?"
  read -r git_authorname
  user "Git author email?"
  read -r git_authoremail

  sed \
    -e "s/AUTHORNAME/$git_authorname/g" \
    -e "s/AUTHOREMAIL/$git_authoremail/g" \
    -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" \
    "$DOTFILES_ROOT/git/.gitconfig.local.example" >"$DOTFILES_ROOT/git/.gitconfig.local"

  success "created git/.gitconfig.local"
}

install_dotfiles() {
  while IFS= read -r -d '' src; do
    local dst="$HOME/$(basename "$src")"
    link_file "$src" "$dst"
  done < <(
    find -H "$DOTFILES_ROOT" \
      -mindepth 2 \
      -maxdepth 2 \
      -name '.*' \
      ! -name '.DS_Store' \
      ! -name '*.example' \
      ! -path '*/.git/*' \
      -print0
  )
}

run_installers() {
  while IFS= read -r installer; do
    success "running ${installer#$DOTFILES_ROOT/}"
    (
      cd "$(dirname "$installer")"
      DOTFILES_ROOT="$DOTFILES_ROOT" bash "$installer"
    )
  done < <(
    find "$DOTFILES_ROOT" \
      -name install.sh \
      ! -path "$DOTFILES_ROOT/.git/*" \
      -print | sort
  )
}

link_file() {
  local src=$1
  local dst=$2
  local overwrite=false
  local backup=false
  local skip=false
  local action=

  if [ -e "$dst" ] || [ -L "$dst" ]; then
    local current_src=
    current_src="$(readlink "$dst" 2>/dev/null || true)"

    if [ "$current_src" = "$src" ]; then
      skip=true
    elif [ "$overwrite_all" = false ] && [ "$backup_all" = false ] && [ "$skip_all" = false ]; then
      user "File exists: $dst ($(basename "$src")). [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
      read -r -n 1 action
      printf '\n'

      case "$action" in
        o) overwrite=true ;;
        O) overwrite_all=true ;;
        b) backup=true ;;
        B) backup_all=true ;;
        s) skip=true ;;
        S) skip_all=true ;;
        *) skip=true ;;
      esac
    fi

    [ "$overwrite_all" = true ] && overwrite=true
    [ "$backup_all" = true ] && backup=true
    [ "$skip_all" = true ] && skip=true

    if [ "$overwrite" = true ]; then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" = true ]; then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" = true ]; then
      success "skipped $dst"
    fi
  fi

  if [ "$skip" != true ]; then
    ln -s "$src" "$dst"
    success "linked $dst"
  fi
}

heading() {
  printf '\n  [..] %s%s%s\n' "$HL" "$1" "$END"
}

user() {
  printf '  [??] %s\n' "$1"
}

success() {
  printf '  [OK] %s\n' "$1"
}

fail() {
  printf '  [FAIL] %s%s%s\n' "$WARN" "$1" "$END"
  exit 1
}

main "$@"
