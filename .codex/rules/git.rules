# Robocollab git workflow backstop for Codex exec policy.
#
# These rules are intentionally narrower than the prose repo rules:
# - Codex `.rules` files only govern commands requested outside the sandbox.
# - Some intent-based policies cannot be encoded exactly, so this file focuses
#   on high-value enforcement for wrapper usage and risky git operations.
# - Prose instructions require `rtk` for raw shell commands, so these rules
#   only cover the `rtk`-prefixed forms. Bare `git`/`gh` invocations fall
#   through to Codex defaults.

prefix_rule(
    pattern = [[
        ".ai/scripts/git.sh", "./.ai/scripts/git.sh",
    ]],
    decision = "allow",
    justification = "This single project wrapper entrypoint is the approved git workflow surface, and one approval covers all supported subcommands.",
    match = [
        ".ai/scripts/git.sh start",
        "./.ai/scripts/git.sh branch feature/example",
        ".ai/scripts/git.sh commit \"feat: add example\"",
        "./.ai/scripts/git.sh push",
        ".ai/scripts/git.sh pr --title Test --body Body",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", ["status", "diff", "log", "rev-parse", "show"]],
    decision = "allow",
    justification = "These rtk-wrapped git commands are read-only inspection commands.",
    match = [
        "rtk git status",
        "rtk git diff --stat",
        "rtk git log --oneline -5",
        "rtk git rev-parse --abbrev-ref HEAD",
        "rtk git show --stat HEAD~1",
    ],
)

# `git branch` is not safe to allow broadly because it also covers mutating
# forms such as `git branch -D ...`.
prefix_rule(
    pattern = ["rtk", "git", "branch", ["--show-current", "--list"]],
    decision = "allow",
    justification = "These rtk-wrapped `git branch` forms are read-only.",
    match = [
        "rtk git branch --show-current",
        "rtk git branch --list",
        "rtk git branch --list 'feature/*'",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", ["add", "commit", "push"]],
    decision = "forbidden",
    justification = "Use `.ai/scripts/git.sh commit`, `.ai/scripts/git.sh push`, or `.ai/scripts/git.sh pr` instead so repo guardrails stay intact.",
    match = [
        "rtk git add .",
        "rtk git commit -m test",
        "rtk git commit --amend -m test",
        "rtk git commit --no-verify -m test",
        "rtk git push",
        "rtk git push --set-upstream origin feature/example",
        "rtk git push --force-with-lease origin feature/example",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "checkout", "-b"],
    decision = "forbidden",
    justification = "Use `.ai/scripts/git.sh branch <branch-name>` instead of creating branches directly with git.",
    match = [
        "rtk git checkout -b feature/example",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", "switch", "-c"],
    decision = "forbidden",
    justification = "Use `.ai/scripts/git.sh branch <branch-name>` instead of creating branches directly with git.",
    match = [
        "rtk git switch -c feature/example",
    ],
)

prefix_rule(
    pattern = ["rtk", "gh", "pr", "create"],
    decision = "forbidden",
    justification = "Use `.ai/scripts/git.sh pr <gh pr create args>` so the PR uses the recorded base branch and normal push flow.",
    match = [
        "rtk gh pr create --title Test --body Body",
    ],
)

prefix_rule(
    pattern = ["rtk", "git", [
        "reset", "rebase", "config", "checkout", "switch", "merge",
        "cherry-pick", "restore", "stash", "clean", "fetch", "pull",
        "clone", "tag", "remote", "worktree", "submodule",
    ]],
    decision = "prompt",
    justification = "This repo requires explicit approval for git operations that are not wrapper-based or explicitly read-only.",
    match = [
        "rtk git reset --hard HEAD~1",
        "rtk git rebase origin/main",
        "rtk git config --get user.name",
        "rtk git checkout feature/example",
        "rtk git switch feature/example",
        "rtk git merge origin/main",
        "rtk git stash push -u",
        "rtk git clean -fd",
        "rtk git fetch origin",
        "rtk git pull --ff-only",
        "rtk git clone git@github.com:example/repo.git",
    ],
)
